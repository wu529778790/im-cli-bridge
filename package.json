{
  "name": "@wu529778790/open-im",
  "version": "0.1.0",
  "description": "Multi-platform IM bridge for AI CLI tools (Claude, Codex, Cursor)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "open-im": "dist/cli.js"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "foreground": "node dist/cli.js dev",
    "setup": "node dist/index.js --setup-only",
    "test": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "telegram",
    "feishu",
    "claude",
    "claude-code",
    "bot",
    "bridge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wu529778790/open-im.git"
  },
  "homepage": "https://github.com/wu529778790/open-im#readme",
  "bugs": {
    "url": "https://github.com/wu529778790/open-im/issues"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "prompts": "^2.4.2",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "dotenv": "^16.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
