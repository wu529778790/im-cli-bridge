{
  "name": "im-cli-bridge",
  "version": "1.0.0",
  "description": "Bridge between IM platforms (Telegram) and Claude CLI",
  "main": "dist/index.js",
  "bin": {
    "im-cli-bridge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts run",
    "start": "node dist/cli.js run",
    "start:bg": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "start:direct": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "pkg:build": "npm run build && esbuild src/cli.ts --bundle --platform=node --target=node18 --outfile=dist/bundle.js && pkg dist/bundle.js --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output dist/im-cli-bridge"
  },
  "keywords": [
    "telegram",
    "cli",
    "bridge",
    "im",
    "bot",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wu529778790/im-cli-bridge"
  },
  "pkg": {
    "assets": [
      "node_modules/axios/dist/**/*.js",
      "dist/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.64.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/node-telegram-bot-api": "^0.64.3",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "files": [
    "dist",
    ".env.example",
    "README.md",
    "README.zh-CN.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
