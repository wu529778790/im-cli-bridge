{
  "name": "@wu529778790/open-im",
  "version": "1.8.1-beta.5",
  "description": "Multi-platform IM bridge for AI CLI tools (Claude, Codex, CodeBuddy)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "open-im": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "init": "tsx src/cli.ts init",
    "start": "node dist/cli.js start",
    "stop": "node dist/cli.js stop",
    "restart": "node dist/cli.js restart",
    "dashboard": "node dist/cli.js dashboard",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dingtalk",
    "telegram",
    "feishu",
    "wechat",
    "weixin",
    "claude",
    "claude-code",
    "bot",
    "bridge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wu529778790/open-im.git"
  },
  "homepage": "https://github.com/wu529778790/open-im#readme",
  "bugs": {
    "url": "https://github.com/wu529778790/open-im/issues"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "centrifuge": "^5.3.0",
    "dingtalk-stream": "^2.1.4",
    "prompts": "^2.4.2",
    "qq-official-bot": "^1.0.12",
    "qrcode-terminal": "^0.12.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.5.13",
    "dotenv": "^17.3.1",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
