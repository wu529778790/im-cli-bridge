{
  "name": "im-cli-bridge",
  "version": "1.0.0",
  "description": "Bridge between IM platforms (Feishu, Telegram) and CLI tools",
  "main": "dist/index.js",
  "bin": {
    "im-cli-bridge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js",
    "start:direct": "node dist/index.js",
    "test": "jest",
    "pkg:build": "npm run build && pkg . --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output dist/im-cli-bridge"
  },
  "keywords": [
    "feishu",
    "telegram",
    "cli",
    "bridge",
    "im",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.64.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/node-telegram-bot-api": "^0.64.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
