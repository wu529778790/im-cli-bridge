# 放在 ~/.im-cli-bridge/.env
# 或使用环境变量：export TELEGRAM_BOT_TOKEN=xxx

# Telegram（必填）
TELEGRAM_BOT_TOKEN=your_bot_token

# AI CLI（默认 claude，可选 codex/cursor）
AI_COMMAND=claude

# 运行模式：oneshot（默认，每次 -p 调用）| tmux（常驻会话，需 tmux）
# MODE=tmux

# Tmux 模式配置
# TMUX_SESSION_NAME=im-cli-bridge
# MONITOR_POLL_INTERVAL=2
# CLAUDE_WORK_DIR=~/Code

# 日志级别
LOG_LEVEL=info
