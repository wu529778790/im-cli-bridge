# Server Configuration
PORT=3000
HOST=localhost

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# Feishu Configuration
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key_here
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token_here

# AI CLI Command Configuration
# The AI CLI tool to use for processing messages
# Presets: claude, claudecode, codex, cursor, aider (see src/config/ai-adapters.ts)
AI_COMMAND=claude

# Session mode: one persistent process per user (requires CLI to work without TTY)
# Most CLIs (codex, claude) error "stdin is not a terminal" - keep false
AI_SESSION_MODE=false

# Execution Configuration
MAX_COMMAND_TIMEOUT=30000
ALLOWED_COMMANDS=ls,pwd,echo,cat
WORKING_DIRECTORY=/path/to/allowed/directory

# Watchdog Configuration (auto-restart on hang)
WATCHDOG_ENABLED=true
WATCHDOG_TIMEOUT=60000

# Logging Configuration
LOG_LEVEL=info
